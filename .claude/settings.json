{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "bash scripts/generate-project-map.sh && git add PROJECT_MAP.md",
            "timeout": 60,
            "statusMessage": "Regenerating PROJECT_MAP.md..."
          }
        ]
      }
    ]
  }
}
