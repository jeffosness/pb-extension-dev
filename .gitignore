############################################
# OS / editor
############################################
.DS_Store
Thumbs.db
.vscode/
.idea/
.sfdx/

############################################
# Archives / junk
############################################
*.zip
*.7z
*.tar
*.tar.gz

############################################
# Node / build output (if used later)
############################################
node_modules/
dist/

############################################
# Server: keep secrets and runtime OUT of git
############################################

# Server-local config (contains secrets/paths) - NEVER COMMIT
server/public/config.php

# Runtime state (Apache writes here) - NEVER COMMIT
# Use /* pattern so .htaccess protection files can be tracked
server/public/tokens/*
server/public/sessions/*
server/public/daily_stats/*
server/public/user_settings/*
server/public/metrics/*
server/public/cache/*

# Track .htaccess files that block HTTP access to sensitive dirs
!server/public/tokens/.htaccess
!server/public/sessions/.htaccess
!server/public/daily_stats/.htaccess
!server/public/user_settings/.htaccess
!server/public/metrics/.htaccess
!server/public/cache/.htaccess

# Server-only logs outside webroot
var/log/
*.log

############################################
# Server-only symlink on the VPS
############################################
# On the server you create: /opt/pb-extension-dev/public -> /opt/pb-extension-dev/server/public
# That symlink is server-only; do not track a top-level "public" folder in git.
/public/

############################################
# IMPORTANT: Do NOT ignore server/public in general
# We WANT server/public/api/** tracked.
############################################
